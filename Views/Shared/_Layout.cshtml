@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafe Delight</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="cd-header">
        <div class="cd-container cd-header-content">
            <div class="cd-logo">Cafe Delight</div>
            <button class="cd-mobile-menu-btn" onclick="toggleMobileMenu()">☰</button>
            <div class="cd-nav-wrapper" id="mobileNavWrapper">
                <nav class="cd-nav">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-area="" asp-controller="Home" asp-action="Menu">Menu</a>
                    <a asp-area="" asp-controller="Home" asp-action="About">About</a>
                    <a asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                    <a href="#" onclick="openAdminModal(event)">Admin Login</a>
                </nav>
                <div class="cd-header-actions">
                    <a asp-area="" asp-controller="Account" asp-action="Register" class="cd-btn cd-btn-outline">Sign Up</a>
                    <a asp-area="" asp-controller="Account" asp-action="Login" class="cd-btn cd-btn-solid">Login</a>
                </div>
            </div>
        </div>
    </header>

    <main class="cd-main">
        @RenderBody()
    </main>

    <footer class="cd-footer">
        <div class="cd-container cd-footer-content">
            <div class="cd-footer-column">
                <h4>Cafe Delight</h4>
                <p>The perfect place to relax, enjoy coffee, and work quietly.</p>
                <p>123 Coffee Street<br />Brew City, 45678</p>
            </div>
            <div class="cd-footer-column">
                <h4>Quick Links</h4>
                <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a asp-area="" asp-controller="Home" asp-action="Menu">Menu</a>
                <a asp-area="" asp-controller="Home" asp-action="About">About Us</a>
                <a asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
            </div>
            <div class="cd-footer-column">
                <h4>Contact Info</h4>
                <p>+1 (555) 123-4567</p>
                <p>hello@cafedelight.com</p>
            </div>
        </div>
        <div class="cd-footer-bottom">
            &copy; @DateTime.Now.Year Cafe Delight. All rights reserved.
        </div>
    </footer>

    <!-- Admin Login Modal -->
    <div id="adminLoginModal" class="admin-modal-overlay">
        <div class="admin-modal-content">
            <button class="admin-modal-close" onclick="closeAdminModal()">×</button>
            <div class="admin-modal-header">
                <div class="admin-modal-icon">☕</div>
                <h2>Cafe Delight</h2>
                <p>Admin Panel Login</p>
            </div>
            <form action="/Admin/Dashboard" method="get" class="admin-modal-form">
                <div class="admin-modal-group">
                    <label>Email Address</label>
                    <input type="email" name="email" required />
                </div>
                <div class="admin-modal-group">
                    <div class="admin-modal-label-row">
                        <label>Password</label>
                        <a href="#" class="admin-forgot-pw">Forgot Password?</a>
                    </div>
                    <input type="password" name="password" required />
                </div>
                <button type="submit" class="admin-modal-submit">Sign In ➔</button>
            </form>
            <div style="margin-top: 25px; color: #a0a0a0; font-size: 11px;">
                © 2025 Cafe Delight. All rights reserved.
            </div>
        </div>
    </div>

    <style>
        .admin-modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(245, 240, 235, 0.95);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }
        .admin-modal-content {
            background: #fff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            width: 100%;
            max-width: 320px;
            position: relative;
            text-align: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .admin-modal-close {
            position: absolute;
            top: 15px; right: 15px;
            background: none; border: none;
            font-size: 24px; color: #999;
            cursor: pointer;
        }
        .admin-modal-close:hover {
            color: #333;
        }
        .admin-modal-icon {
            background-color: #6C4A3A;
            color: white;
            width: 48px; height: 48px;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            border-radius: 8px;
            font-size: 24px;
            margin-bottom: 16px;
        }
        .admin-modal-header h2 {
            margin: 0 0 5px;
            color: #333;
            font-size: 20px;
            font-weight: 700;
        }
        .admin-modal-header p {
            margin: 0 0 25px;
            color: #888;
            font-size: 13px;
        }
        .admin-modal-group {
            text-align: left;
            margin-bottom: 20px;
        }
        .admin-modal-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #444;
            margin-bottom: 8px;
        }
        .admin-modal-label-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        .admin-modal-label-row label {
            margin-bottom: 0;
        }
        .admin-forgot-pw {
            font-size: 11px;
            color: #6C4A3A;
            text-decoration: none;
            font-weight: 600;
        }
        .admin-modal-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            background-color: #f9f9f9;
            font-size: 14px;
            box-sizing: border-box;
            outline: none;
        }
        .admin-modal-group input:focus {
            border-color: #6C4A3A;
            background-color: #fff;
        }
        .admin-modal-submit {
            width: 100%;
            padding: 14px;
            background-color: #6C4A3A;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 5px;
        }
        .admin-modal-submit:hover {
            background-color: #553a2d;
        }
        @@media (max-width: 480px) {
            .admin-modal-content {
                padding: 25px 20px;
                width: 90%;
            }
        }
    </style>
    <script>
        function toggleMobileMenu() {
            var nav = document.getElementById('mobileNavWrapper');
            if (nav.classList.contains('active')) {
                nav.classList.remove('active');
            } else {
                nav.classList.add('active');
            }
        }
        function openAdminModal(e) {
            if (e) e.preventDefault();
            document.getElementById('adminLoginModal').style.display = 'flex';
        }
        function closeAdminModal() {
            document.getElementById('adminLoginModal').style.display = 'none';
        }
        window.addEventListener('click', function(e) {
            const modal = document.getElementById('adminLoginModal');
            if (e.target === modal) {
                closeAdminModal();
            }
        });
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

