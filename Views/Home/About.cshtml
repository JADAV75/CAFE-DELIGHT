@{
    ViewData["Title"] = "About Us";
}

<div class="cd-about-page">
    <div class="cd-container">
        <!-- Top heading -->
        <section class="cd-section cd-about-hero">
            <h1 class="cd-section-title">About Us</h1>
            <p class="cd-section-subtitle">
                More than just a coffee shop. We are a community of coffee lovers.
            </p>
        </section>

        <!-- Our Story + image -->
        <section class="cd-section cd-about-story">
            <div class="cd-about-layout">
                <div class="cd-about-content">
                    <h2 class="cd-section-title">Our Story</h2>
                    <p>
                        Founded in 2016, Cafe Delight started as a simple dream: to create a warm,
                        welcoming place where people can slow down, connect, and enjoy truly great coffee.
                    </p>
                    <p>
                        We carefully source our beans from trusted farms, roast them to perfection,
                        and craft every drink with care. Whether you are studying, working remotely,
                        or catching up with friends, our space is designed to feel like your second home.
                    </p>
                    <button type="button" class="cd-btn cd-btn-solid cd-about-btn">
                        Read More
                    </button>
                </div>
                <div class="cd-about-image"
                     style="background-image:url('https://images.pexels.com/photos/1005058/pexels-photo-1005058.jpeg?auto=compress&cs=tinysrgb&w=1200');">
                </div>
            </div>
        </section>

        <!-- Feature cards -->
        <section class="cd-section cd-about-features">
            <div class="cd-specials-grid">
                <article class="cd-card cd-feature-card">
                    <div class="cd-card-body">
                        <h3 class="cd-card-title">Premium Quality</h3>
                        <p class="cd-card-text">
                            We source the finest Arabica beans from ethical growers and brew them fresh
                            for every cup.
                        </p>
                    </div>
                </article>
                <article class="cd-card cd-feature-card">
                    <div class="cd-card-body">
                        <h3 class="cd-card-title">Community First</h3>
                        <p class="cd-card-text">
                            A cozy, inclusive space for conversations, study groups, and local events
                            that bring people together.
                        </p>
                    </div>
                </article>
                <article class="cd-card cd-feature-card">
                    <div class="cd-card-body">
                        <h3 class="cd-card-title">Sustainability</h3>
                        <p class="cd-card-text">
                            From reusable cups to responsible sourcing, we are committed to better,
                            greener coffee habits.
                        </p>
                    </div>
                </article>
            </div>
        </section>

        <!-- Team section -->
        <section class="cd-section cd-about-team">
            <div class="cd-section-header">
                <h2 class="cd-section-title">Meet the Team</h2>
                <p class="cd-section-subtitle">
                    The friendly faces making your daily brew special.
                </p>
            </div>

            <div class="cd-team-grid">
                <article class="cd-team-card">
                    <div class="cd-team-avatar"
                         style="background-image:url('https://images.pexels.com/photos/3218467/pexels-photo-3218467.jpeg?auto=compress&cs=tinysrgb&w=400');">
                    </div>
                    <h3 class="cd-team-name">rohit sarma</h3>
                    <p class="cd-team-role">Head Barista</p>
                </article>

                <article class="cd-team-card">
                    <div class="cd-team-avatar"
                         style="background-image:url('https://images.pexels.com/photos/3760852/pexels-photo-3760852.jpeg?auto=compress&cs=tinysrgb&w=400');">
                    </div>
                    <h3 class="cd-team-name">sonam bajwa</h3>
                    <p class="cd-team-role">Roaster</p>
                </article>

                <article class="cd-team-card">
                    <div class="cd-team-avatar"
                         style="background-image:url('https://images.pexels.com/photos/1181686/pexels-photo-1181686.jpeg?auto=compress&cs=tinysrgb&w=400');">
                    </div>
                    <h3 class="cd-team-name">payal agrval</h3>
                    <p class="cd-team-role">Pastry Chef</p>
                </article>

                <article class="cd-team-card">
                    <div class="cd-team-avatar"
                         style="background-image:url('https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?auto=compress&cs=tinysrgb&w=400');">
                    </div   
                    <h3 class="cd-team-name">HARDIK GOHEL</h3>
                    <p class="cd-team-role">Store Manager</p>
                </article>
            </div>
        </section>
    </div>
</div>