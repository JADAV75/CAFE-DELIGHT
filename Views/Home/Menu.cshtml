<script>
    (function () {
        var STORAGE_KEY = 'cd_products_v1';
        var DEFAULT_IMAGE = 'https://images.pexels.com/photos/302899/pexels-photo-302899.jpeg?auto=compress&cs=tinysrgb&w=800';

        function loadProducts() {
            try {
                var raw = window.localStorage ? window.localStorage.getItem(STORAGE_KEY) : null;
                if (!raw) return [];
                var parsed = JSON.parse(raw);
                return Array.isArray(parsed) ? parsed : [];
            } catch (e) {
                return [];
            }
        }

        var products = loadProducts();
        
        // Ensure same seed as Admin if empty
        if (!products || products.length === 0) {
            products = [
                { id: "1", name: "Cappuccino", category: "Hot Coffee", price: "180.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/312418/pexels-photo-312418.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "2", name: "Butter Croissant", category: "Bakery", price: "120.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/1860209/pexels-photo-1860209.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "3", name: "Iced Mocha", category: "Cold Coffee", price: "240.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/4109744/pexels-photo-4109744.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "4", name: "Chocolate Muffin", category: "Bakery", price: "170.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/6930269/pexels-photo-6930269.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "5", name: "Double Espresso", category: "Hot Coffee", price: "140.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/2396220/pexels-photo-2396220.jpeg?auto=compress&cs=tinysrgb&w=800" }
            ];
            try { window.localStorage.setItem(STORAGE_KEY, JSON.stringify(products)); } catch(e){}
        }

        var container = document.querySelector('.menu-grid');
        if (!container) return;

        // Clear existing static menu items
        container.innerHTML = '';

        function createMenuCard(product) {
            var name = product.name || '';
            var price = product.price;
            var image = product.image || DEFAULT_IMAGE;
            var description = product.description || product.category || '';
            var status = (product.status || 'Active').toString();

            var card = document.createElement('div');
            card.className = 'menu-card';

            card.innerHTML =
                '<img src="' + image + '" alt="" />' +
                '<div class="menu-card-body">' +
                '  <h3>' + name.replace(/</g, '&lt;').replace(/>/g, '&gt;') + ' <span class="price">₹' + price + '</span></h3>' +
                '  <p>' + (description || '') + '</p>' +
                '  <button type="button" class="add-btn" data-name="' + name + '" data-price="' + price + '" data-image="' + (image || '') + '">' +
                (status.toLowerCase() === 'out of stock' || status.toLowerCase() === 'out' ? 'Out of Stock' : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 4px; vertical-align: text-bottom;"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg> Add to Cart') +
                '  </button>' +
                '</div>';

            var btn = card.querySelector('button.add-btn[data-name]');
            if (status.toLowerCase() === 'out of stock' || status.toLowerCase() === 'out') {
                btn.disabled = true;
            }

            // If image URL is broken, show a clean placeholder.
            var img = card.querySelector('img');
            if (img) {
                img.addEventListener('error', function () {
                    img.src = DEFAULT_IMAGE;
                }, { once: true });
            }

            return card;
        }

        products.forEach(function (product) {
            if (!product || product.deleted) return;
            if (!product.name) return;
            container.appendChild(createMenuCard(product));
        });
    })();
</script>
