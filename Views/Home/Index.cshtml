    <section class="cd-section cd-about">
        <div class="cd-about-layout">
            <div class="cd-about-image" style="background-image: url('https://images.pexels.com/photos/1005058/pexels-photo-1005058.jpeg?auto=compress&cs=tinysrgb&w=800');"></div>
            <div class="cd-about-content">
                <h2 class="cd-section-title">About Us</h2>
                <p>
                    Cafe Delight is your neighborhood coffee spot where every cup is brewed with care.
                    From single-origin beans to freshly baked pastries, we focus on quality and comfort.
                </p>
                <p>
                    Whether you're catching up with friends, studying, or working remotely, our cozy
                    space and friendly team are here to make you feel at home.
                </p>
                <a asp-controller="Home" asp-action="About" class="cd-btn cd-btn-solid">Learn More</a>
            </div>
        </div>
    </section>
</div>

<script>
    (function () {
        var STORAGE_KEY = 'cd_products_v1';
        var DEFAULT_IMAGE = 'https://images.pexels.com/photos/302899/pexels-photo-302899.jpeg?auto=compress&cs=tinysrgb&w=800';

        function loadProducts() {
            try {
                var raw = window.localStorage ? window.localStorage.getItem(STORAGE_KEY) : null;
                if (!raw) return [];
                var parsed = JSON.parse(raw);
                return Array.isArray(parsed) ? parsed : [];
            } catch (e) {
                return [];
            }
        }

        var products = loadProducts();
        
        // Ensure same seed as Admin if empty
        if (!products || products.length === 0) {
            products = [
                { id: "1", name: "Cappuccino", category: "Hot Coffee", price: "180.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/312418/pexels-photo-312418.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "2", name: "Butter Croissant", category: "Bakery", price: "120.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/1860209/pexels-photo-1860209.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "3", name: "Iced Mocha", category: "Cold Coffee", price: "240.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/4109744/pexels-photo-4109744.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "4", name: "Chocolate Muffin", category: "Bakery", price: "170.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/6930269/pexels-photo-6930269.jpeg?auto=compress&cs=tinysrgb&w=800" },
                { id: "5", name: "Double Espresso", category: "Hot Coffee", price: "140.00", status: "Active", deleted: false, image: "https://images.pexels.com/photos/2396220/pexels-photo-2396220.jpeg?auto=compress&cs=tinysrgb&w=800" }
            ];
            try { window.localStorage.setItem(STORAGE_KEY, JSON.stringify(products)); } catch(e){}
        }

        var container = document.querySelector('.cd-specials-grid');
        if (!container) return;

        // Clear existing static items 
        container.innerHTML = '';

        function createCard(product) {
            var name = product.name || '';
            var price = product.price;
            var image = product.image || DEFAULT_IMAGE;
            var description = product.description || '';
            var status = (product.status || 'Active').toString();

            var card = document.createElement('article');
            card.className = 'cd-card';

            var imgStyle = image ? "background-image: url('" + image + "');" : '';
            card.innerHTML =
                '<div class="cd-card-image" style="' + imgStyle + '"></div>' +
                '<div class="cd-card-body">' +
                '  <h3 class="cd-card-title"></h3>' +
                '  <p class="cd-card-text"></p>' +
                '  <div class="cd-card-footer">' +
                '    <span class="cd-card-price"></span><br />' +
                '    <button type="button" class="add-btn" data-name="' + name + '" data-price="' + price + '" data-image="' + image + '">' +
                '      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 4px; vertical-align: text-bottom;"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg> Add to Cart' +
                '    </button>' +
                '  </div>' +
                '</div>';

            card.querySelector('.cd-card-title').textContent = name;
            card.querySelector('.cd-card-text').textContent = description;
            card.querySelector('.cd-card-price').textContent = '₹' + price;

            var btn = card.querySelector('button.add-btn[data-name]');
            if (status.toLowerCase() === 'out of stock' || status.toLowerCase() === 'out') {
                btn.disabled = true;
                btn.textContent = 'Out of Stock';
            }

            return card;
        }

        products.forEach(function (product) {
            if (!product || product.deleted) return;
            if (!product.name) return;
            container.appendChild(createCard(product));
        });
    })();
</script>
