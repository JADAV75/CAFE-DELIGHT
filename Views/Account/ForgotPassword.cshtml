@{
    ViewData["Title"] = "Forgot Password";
}

<div class="cd-auth-card">
    <h1 class="cd-auth-title">Forgot Password</h1>
    <p class="cd-auth-subtitle">
        Enter your email address. We will send you a link to reset your password.
    </p>

    <form asp-controller="Account" asp-action="ForgotPassword" method="post">
        <div class="cd-form-group">
            <label for="Email">Email Address</label>
            <input class="cd-input" type="email" id="Email" name="email" placeholder="name@example.com" required />
        </div>

        <button type="submit" class="cd-btn cd-btn-solid cd-submit-btn">
            Send Reset Link
        </button>

        <div class="cd-auth-bottom-text">
            Remember your password?
            <a asp-controller="Account" asp-action="Login">Back to login</a>
        </div>
    </form>
</div>

